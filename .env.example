KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_CANO=your_account_number
KIS_ACNT_PRDT_CD=01

WATCHLIST=AAPL,MSFT,NVDA,META,AMZN,GOOGL,TSLA,AMD,AVGO,NFLX,PLTR,CRWD,TSM,SHOP,UBER,LLY,UNH,JNJ,JPM,V,XOM,COST,WMT,KO,CAT
USE_SPY_MARKET_FILTER=true
USE_QQQ_REGIME_FILTER=true
USE_REGIME_GOLDEN_CROSS=true
REGIME_CAUTIOUS_MAX_POSITIONS=2
USE_VOL_ADJUSTED_RISK=true
VOL_TARGET_PCT=0.015
USE_SCALE_IN=true
USE_SCALE_OUT=true
USE_WEEKLY_TREND_FILTER=true
WEEKLY_TREND_SMA_PERIOD=20
USE_52W_HIGH_FILTER=true
NEAR_52W_HIGH_PCT=0.05
# Total deployable portfolio (USD). Phase 4 splits: Legacy 60% + Top3 40%.
CAPITAL_AT_RISK=100000
RISK_PER_TRADE=0.01
LOOP_COOLDOWN_SECONDS=60
# Faster RTH polling when holding positions or pending orders (ATR stop responsiveness)
LOOP_COOLDOWN_HELD_SECONDS=15
TICKER_SLEEP_SECONDS=1
MARKET_CLOSED_SLEEP_SECONDS=3600
# Off-hours weekday sleep cap (longer = fewer idle wakeups; still wakes ~15m before RTH)
OFF_HOURS_MAX_SLEEP_SECONDS=7200
# Parallel OHLCV refresh (VTS mock: keep false — burst calls trigger HTTP 500)
PARALLEL_TICKER_REFRESH=false
TICKER_REFRESH_WORKERS=3
KIS_REFRESH_STAGGER_SECONDS=1.0
OHLCV_MIN_REFRESH_SECONDS=120
RECONCILE_RETRY_COOLDOWN_SECONDS=900
KIS_DAILYPRICE_RETRY_BACKOFF_SECONDS=2.0
CACHE_GC_EVERY_N_CYCLES=60
TELEGRAM_ALERT_THROTTLE_SECONDS=900
KIS_REQUEST_TIMEOUT_SECONDS=30
KIS_SLOW_API_MS=3000
KIS_ORDER_MAX_RETRIES=3
KIS_ORDER_RETRY_BACKOFF_SECONDS=2.0
ORDER_RETRY_QUEUE_FILE=./order_retry_queue.json

# Live/backtest ATR stop parity (true = daily bar low only, matches backtest)
USE_EOD_ATR_STOPS=false

# KIS VTS defaults to limit orders when BASE_URL is openapivts (mock sandbox).
KIS_ORDER_TYPE=limit
KIS_LIMIT_PRICE_BUFFER_BPS=10
KIS_HIGH_VOL_LIMIT_BUFFER_BPS=15

# Fill verification + risk gates (Phase 6)
TRADE_LOG_FILE=./trade_log.csv
MAX_DAILY_LOSS_USD=5000
MAX_OPEN_POSITIONS=5
MAX_TICKER_EXPOSURE_USD=25000
MAX_PORTFOLIO_USD=100000
OVERDEPLOYMENT_TRIM_ENABLED=true
OVERDEPLOYMENT_TRIM_TARGET_PCT=0.98
RTH_BUY_BLOCK_OPEN_MINUTES=10
RTH_BUY_BLOCK_CLOSE_MINUTES=5
PENDING_ORDER_STALE_MINUTES=120
PENDING_ORDER_CANCEL_MINUTES=45
MAX_CONSECUTIVE_LOSS_DAYS=3
MAX_POSITIONS_PER_SECTOR=2

# Momentum rank (Top N from full WATCHLIST universe; new BUY only)
# Phase 1 default: disabled — Top3 runs as separate strategy in phases 2–4
MOMENTUM_RANK_ENABLED=false
MOMENTUM_TOP_N=3
MOMENTUM_REBALANCE_WEEKDAY=4
MOMENTUM_WEIGHT_3M=0.4
MOMENTUM_WEIGHT_6M=0.3
MOMENTUM_WEIGHT_12M=0.2
MOMENTUM_WEIGHT_VOLUME=0.1
MOMENTUM_REQUIRE_SMA50=true
MOMENTUM_REQUIRE_SMA200=false
MOMENTUM_REQUIRE_NEAR_52W_HIGH=true
MOMENTUM_NEAR_52W_HIGH_PCT=0.05
MOMENTUM_SECTOR_DIVERSIFY=true
MOMENTUM_MAX_PER_SECTOR=1

# --- Production: legacy momentum ranking (63/126/252 + volume, equal-weight Top3) ---
# Enhanced mode below is RESEARCH ONLY — backtested 2020-2026; Legacy won; not deployed.
MOMENTUM_RANKING_MODE=legacy
# MOMENTUM_RANKING_MODE=enhanced   # DO NOT use in production .env
MOMENTUM_WEIGHT_MOMENTUM=1.0
MOMENTUM_WEIGHT_FIP=1.0
MOMENTUM_WEIGHT_SKEW_PENALTY=1.0
MOMENTUM_DYNAMIC_REBALANCE=true
MOMENTUM_INVERSE_VOL_WEIGHT=true

# Four-phase dual-strategy deployment (see README §8, docs/OPERATIONS.md §15)
# Phase 4 production: $100k total → Legacy $60k + Top3 $40k sizing pools
DEPLOYMENT_PHASE=4
STRATEGY_MODE=dual
TOP3_BACKTEST_ONLY=false
TOP3_DRY_RUN_ENABLED=false
LEGACY_CAPITAL_PCT=60
TOP3_CAPITAL_PCT=40

# KIS API environment (default: VTS sandbox — do not point at live without guards below)
KIS_ENVIRONMENT=vts
# KIS_BASE_URL=   # optional override; must match KIS_ENVIRONMENT
# KIS_LIVE_CONFIRMED=false
# KIS_LIVE_MAX_CAPITAL=500000
# KIS_LIVE_HIGH_CAPITAL_CONFIRMED=false

# KIS dry-run: simulate orders locally without broker API calls
KIS_DRY_RUN=false

# End-of-day Telegram summary (sent once per NY session after 16:00 ET)
USE_DAILY_TELEGRAM_REPORT=true

USE_TELEGRAM_ALERTS=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_MAX_RETRIES=3
TELEGRAM_BACKOFF_SECONDS=1.0